# Server Configuration
PORT=5000

# MongoDB (Add your own MongoDB Atlas URI here)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/electionedu?retryWrites=true&w=majority

# Google Gemini AI (Add your own Gemini API Key here)
# Get your free API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Environment
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Secret (optional, for future auth features)
JWT_SECRET=your_random_jwt_secret_here
